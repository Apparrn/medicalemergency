def call_ambulance(patient_name, disease, severity, location="Not available"):
    """
    Make automated voice call to ambulance with patient details.

    Args:
        patient_name : Patient's name
        disease      : Predicted disease
        severity     : Low / Medium / Critical
        location     : Patient location description
    """
    client = Client(ACCOUNT_SID, AUTH_TOKEN)

    # Text-to-speech message for the call
    twiml_message = f"""
    <Response>
        <Say voice="alice" language="en-IN">
            Attention! This is an automated Medical Emergency Alert.
            Patient name: {patient_name}.
            Predicted condition: {disease}.
            Severity level: {severity}.
            Patient location: {location}.
            Please respond immediately.
            Repeating once more.
            Patient name: {patient_name}.
            Condition: {disease}.
            Severity: {severity}.
            Thank you.
        </Say>
    </Response>
    """

    try:
        call = client.calls.create(
            twiml  = twiml_message,
            to     = AMBULANCE_NUMBER,
            from_  = TWILIO_PHONE
        )
        print(f"✅ Ambulance call initiated!")
        print(f"   Call SID : {call.sid}")
        print(f"   Status   : {call.status}")
        print(f"   To       : {AMBULANCE_NUMBER}")
        return call.sid

    except Exception as e:
        print(f"❌ Failed to call ambulance: {e}")
        return None


def send_sms_alert(patient_name, disease, severity, location_link=None):
    """
    Send SMS alert to ambulance as backup.

    Args:
        patient_name  : Patient's name
        disease       : Predicted disease
        severity      : Severity level
        location_link : Google Maps link
    """
    client = Client(ACCOUNT_SID, AUTH_TOKEN)

    msg = f"🚨 EMERGENCY ALERT\nPatient: {patient_name}\nCondition: {disease}\nSeverity: {severity}"
    if location_link:
        msg += f"\nLocation: {location_link}"

    try:
        message = client.messages.create(
            body  = msg,
            from_ = TWILIO_PHONE,
            to    = AMBULANCE_NUMBER
        )
        print(f"✅ SMS sent! SID: {message.sid}")
        return message.sid
    except Exception as e:
        print(f"❌ SMS failed: {e}")
        return None


def dispatch_emergency(patient_name, disease, severity, location="Unknown", location_link=None):
    """
    Full emergency dispatch — makes voice call AND sends SMS.
    Call this from app.py when emergency is triggered.
    """
    print(f"\n🚑 Dispatching ambulance for: {patient_name}")
    print(f"   Disease  : {disease}")
    print(f"   Severity : {severity}")
    print(f"   Location : {location}")

    # Make voice call
    call_sid = call_ambulance(patient_name, disease, severity, location)

    # Send SMS as backup
    sms_sid  = send_sms_alert(patient_name, disease, severity, location_link)

    return {"call_sid": call_sid, "sms_sid": sms_sid}


